{
  "name": "lupine-template-doc-starter",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "apps/*/*",
    "packages/*"
  ],
  "scripts": {
    "app1:build-win": "electron-builder --win --config apps/lupine-template-doc-starter/electron/builder.json",
    "app1:build-linux": "electron-builder --linux --config apps/lupine-template-doc-starter/electron/builder.json",
    "app1:build-mac": "export CSC_IDENTITY_AUTO_DISCOVERY=true && electron-builder --mac --x64 --config apps/lupine-template-doc-starter/electron/builder.json",
    "app1:unpack-mac": "npx asar extract dist/build/mac-arm64-unpacked/lupine-template-doc-starter.app/Contents/Resources/app.asar dist/build/mac-arm64-unpacked/lupine-template-doc-starter.app/Contents/Resources/app.asar-unpack",
    "app1:unpack-linux": "npx asar extract dist/build/linux-arm64-unpacked/resources/app.asar dist/build/linux-arm64-unpacked/resources/app.asar-unpack",
    "app1:unpack-win": "npx asar extract dist/build/win-unpacked/resources/app.asar dist/build/win-unpacked/resources/app.asar-unpack",
    "app1:desktop": "electron apps/lupine-template-doc-starter/electron/main.js",
    "app1:sync": "npm run sync --workspace=lupine-template-doc-starter-web",
    "app1:open-ios": "npm run open-ios --workspace=lupine-template-doc-starter-web",
    "app1:open-android": "npm run open-android --workspace=lupine-template-doc-starter-web",
    "dev": "node ./dev/dev-watch --env=.env.development --dev=1 --cmd=start-dev",
    "build": "node ./dev/dev-watch --env=.env.production --dev=0 --obfuscate=0",
    "build-mobile": "node ./dev/dev-watch --env=.env.mobile --dev=0 --mobile=1",
    "start-dev": "node dist/server_root/server/app-loader.js --env=.env.development",
    "start-production": "node dist/server_root/server/app-loader.js --env=.env.production",
    "format": "prettier --write \"**/*.{js,json,css,scss,md,html,yaml,ts,jsx,tsx}\"",
    "cp-docs": "node dev/cp-folder.js dist/server_root/lupine-template-doc-starter_web/lupine-template-doc-starter docs"
  },
  "dependencies": {
    "lupine.api": "^1.1.77",
    "lupine.components": "^1.1.21",
    "lupine.web": "^1.1.13",
    "lupine.press": "^1.0.8"
  },
  "devDependencies": {
    "esbuild": "^0.24.2",
    "electron": "^35.2.0",
    "electron-builder": "^26.0.12",
    "typescript": "^5.7.2",
    "@types/node": "^22.10.5",
    "prettier": "^2.7.1",
    "gray-matter": "^4.0.3",
    "marked": "^17.0.1"
  }
}
